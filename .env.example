# ── ANTHROPIC (required) ──────────────────────────────────
# Get your API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: change the model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── SERVER ────────────────────────────────────────────────
# Optional: change the server port (default: 3001)
# PORT=3001

# Python verification service URL (default: http://127.0.0.1:8000)
# Windows users: use 127.0.0.1, not localhost
# PYTHON_SERVICE_URL=http://127.0.0.1:8000

# ── AMADEUS (Flights) ────────────────────────────────────
# Provider: Amadeus (https://developers.amadeus.com)
# Replaces: Google Flights scraper
# Required: Both KEY and SECRET (OAuth2 client credentials)
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
# AMADEUS_API_BASE_URL=https://api.amadeus.com

# ── BOOKING.COM (Hotels) ─────────────────────────────────
# Provider: Booking.com (https://www.booking.com/content/affiliates.html)
# Replaces: Google Hotels + Booking.com scrapers
# Required: KEY only (affiliate ID optional)
# BOOKING_API_KEY=
# BOOKING_AFFILIATE_ID=

# ── VIATOR (Activities) ──────────────────────────────────
# Provider: Viator Partner API (https://partnerapi.viator.com)
# Replaces: Viator + GetYourGuide scrapers
# Required: KEY only
# VIATOR_API_KEY=

# ── GOOGLE MAPS EMBED (Map tab) ──────────────────────────
# Provider: Google Maps Embed API (https://console.cloud.google.com)
# Used for: Route map iframe on the Map tab (free, no billing required)
# Required: KEY only — restrict to Maps Embed API + your domain
VITE_GOOGLE_MAPS_KEY=

# ── GOOGLE PLACES (Reviews + Places) ─────────────────────
# Provider: Google Places API (https://console.cloud.google.com)
# Replaces: Google Search review scraper + enhances place verification
# Required: KEY only
# GOOGLE_PLACES_API_KEY=
