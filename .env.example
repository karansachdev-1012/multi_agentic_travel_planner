# Get your API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: change the model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: change the server port (default: 3001)
# PORT=3001

# Python verification service URL (default: http://127.0.0.1:8000)
# Windows users: use 127.0.0.1, not localhost
# PYTHON_SERVICE_URL=http://127.0.0.1:8000
